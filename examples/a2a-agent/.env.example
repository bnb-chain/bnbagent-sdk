# ── Provider (server.py + register.py) ──
WALLET_KIND=evm                        # evm | twak — switches the provider wallet
PRIVATE_KEY=0x...                      # provider wallet (signs quotes); evm only
WALLET_PASSWORD=demo-password          # evm only — twak resolves its own password
# TWAK_BIN=twak                        # optional: version-pinned twak binary
NETWORK=bsc-testnet                    # bsc-testnet | bsc-mainnet
AGENT_NAME=a2a-demo-agent
AGENT_DESCRIPTION=Demo provider that quotes ERC-8183 jobs over the A2A protocol.
A2A_BASE_URL=http://localhost:8010     # public base URL of the running server
ERC8183_SERVICE_PRICE=1000000000000000000   # minimum budget, raw units (1 token @ 18 decimals)

# ── Buyer (buyer.py) ──
# AGENT_ID=123                         # optional: discover via ERC-8004 instead of A2A_BASE_URL
# BUYER_PRIVATE_KEY=0x...              # optional: enables on-chain create/register/setBudget/fund
# BUYER_WALLET_PASSWORD=demo-password
