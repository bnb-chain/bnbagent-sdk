# examples/client — ERC-8183 client (payer) demo config.
# See project-root .env.example for the full surface.

WALLET_PASSWORD=demo-password

# Wallet backend for the CLIENT role: "evm" (default) or "twak".
# evm  -> signs locally with PRIVATE_KEY (the original behavior).
# twak -> delegates custody + broadcasting to the Trust Wallet Agent Kit CLI.
#         PRIVATE_KEY is then NOT needed for the client role; the client is
#         whatever `twak wallet address` reports. Prerequisites:
#           - `npm i -g @trustwallet/cli` (>= 0.19)
#           - a created + funded twak wallet on the target network
#           - password reachable by twak: TWAK_WALLET_PASSWORD env var or
#             `twak wallet keychain save` (never passed by the SDK)
#         Provider/voter steps still run via the PRIVATE_KEY-style vars below:
#         a host has only ONE twak wallet, so the counterparty stays EVM
#         (the seller role itself works on twak >= v0.19.0, REQ-1 shipped).
WALLET_KIND=evm

# Client wallet (the "payer" in every flow). Required for WALLET_KIND=evm;
# ignored for the client role when WALLET_KIND=twak.
PRIVATE_KEY=0x...

# Provider EOA. Happy / dispute / stalemate flows need the provider to
# submit — set PROVIDER_PRIVATE_KEY too if you want the script to drive
# submit itself (otherwise it prints the jobId and exits).
# For agent_ipfs_test.py, set this to the agent-server wallet address.
PROVIDER_ADDRESS=0x...
PROVIDER_PRIVATE_KEY=

# Voter wallet (only for dispute_reject.py / stalemate_expire.py if the
# script should cast the reject vote itself).
VOTER_PRIVATE_KEY=

# --- Network ---
NETWORK=bsc-testnet
# RPC_URL=

# --- ERC-8183 contract overrides (defaults from NETWORK) ---
# ERC8183_COMMERCE_ADDRESS=
# ERC8183_ROUTER_ADDRESS=
# ERC8183_POLICY_ADDRESS=
