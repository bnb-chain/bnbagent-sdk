# examples/client — APEX client (payer) demo config.
# See project-root .env.example for the full surface.

WALLET_PASSWORD=demo-password

# Client wallet (the "payer" in every flow).
PRIVATE_KEY=0x...

# Provider EOA. Happy / dispute / stalemate flows need the provider to
# submit — set PROVIDER_PRIVATE_KEY too if you want the script to drive
# submit itself (otherwise it prints the jobId and exits).
PROVIDER_ADDRESS=0x...
PROVIDER_PRIVATE_KEY=

# Voter wallet (only for dispute_reject.py / stalemate_expire.py if the
# script should cast the reject vote itself).
VOTER_PRIVATE_KEY=

# --- Network ---
NETWORK=bsc-testnet
# RPC_URL=

# --- APEX contract overrides (defaults from NETWORK) ---
# APEX_COMMERCE_ADDRESS=
# APEX_ROUTER_ADDRESS=
# APEX_POLICY_ADDRESS=
