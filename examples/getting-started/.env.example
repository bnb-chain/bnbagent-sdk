# Quickstart Configuration
# Copy to .env and fill in values

# Required: Password to encrypt/decrypt wallet keystore
WALLET_PASSWORD=quickstart-demo

# First run only: Your private key (with testnet BNB for gas)
# After first run, the key is encrypted in ~/.bnbagent/wallets/
# and this line can be removed.
PRIVATE_KEY=0x...

# Optional: Select a specific wallet (needed only if you have multiple)
# WALLET_ADDRESS=0x...

# Optional: BSC Testnet RPC (defaults to BSC Testnet if not set)
# RPC_URL=https://data-seed-prebsc-2-s2.binance.org:8545/

# Optional: Contract addresses (defaults to BSC Testnet)
# ERC8183_ADDRESS=0x3464e64dD53bC093c53050cE5114062765e9F1b6
# APEX_EVALUATOR_ADDRESS=0x5f4976ACBCD2968D08273bA9f4a67FA43C4A3af3
# PAYMENT_TOKEN_ADDRESS=0xc70B8741B8B07A6d61E54fd4B20f22Fa648E5565

# Optional: Storage
STORAGE_PROVIDER=local

# Optional: Agent pricing (1 U token = 1e18 wei)
AGENT_PRICE=1000000000000000000
