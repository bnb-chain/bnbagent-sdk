# APEX Lifecycle Demo — Client Configuration
#
# This demo drives the full APEX lifecycle from the client side.
# The provider (agent-server) should be running separately.

# Required: Blockchain
RPC_URL=https://data-seed-prebsc-2-s2.binance.org:8545/
ERC8183_ADDRESS=0xf8b6921fea71dfca3482a4a69576198d2072d188
APEX_EVALUATOR_ADDRESS=0xd707433ca1343759ccc127402b18cfdae3f0e10b
PRIVATE_KEY=0x...

# Required: Agent Server (examples/agent-server)
# Get AGENT_SERVER_ADDRESS from the agent-server's on-chain registration (run register.py first)
# AGENT_SERVER_URL matches agent-server default port; change if using a different host/port
AGENT_SERVER_ADDRESS=0x...
AGENT_SERVER_URL=http://localhost:8003

# Optional: Third-party Disputer (separate from client to show clean 1U flow)
# If set, disputes use this key instead of PRIVATE_KEY
DISPUTE_PRIVATE_KEY=

# Required: Payment
PAYMENT_TOKEN_ADDRESS=0xc70B8741B8B07A6d61E54fd4B20f22Fa648E5565

# Optional: ERC-8004 Discovery (set to discover provider automatically)
AGENT_ID=

# Optional: LLM for newsletter generation (Step 6)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Optional
WALLET_PASSWORD=demo-password
STORAGE_API_KEY=
# Optional: IPFS gateway for fetching deliverables (default: Pinata public gateway)
# STORAGE_GATEWAY_URL=https://gateway.pinata.cloud/ipfs/
