# Blockchain News Agent Configuration

# Required: Password to encrypt/decrypt wallet keystore
WALLET_PASSWORD=demo-password

# First run only: Your private key
# After first run, the key is encrypted in ~/.bnbagent/wallets/ and this can be removed.
PRIVATE_KEY=0x...

# Optional: Select a specific wallet (needed only if you have multiple)
# WALLET_ADDRESS=0x...

# Optional: Blockchain (defaults to BSC Testnet)
# RPC_URL=https://data-seed-prebsc-2-s2.binance.org:8545/
# ERC8183_ADDRESS=0x3464e64dD53bC093c53050cE5114062765e9F1b6
# APEX_EVALUATOR_ADDRESS=0x5f4976ACBCD2968D08273bA9f4a67FA43C4A3af3

# Required: IPFS Storage (get JWT from https://app.pinata.cloud)
STORAGE_PROVIDER=ipfs
STORAGE_API_KEY=your_pinata_jwt_here
STORAGE_GATEWAY_URL=https://gateway.pinata.cloud/ipfs/
# Legacy aliases also supported: PINATA_JWT, PINATA_GATEWAY

# Agent Configuration
AGENT_NAME=blockchain-news
AGENT_DESCRIPTION=Blockchain news search agent
AGENT_HOST=http://localhost:8003
SERVICE_PRICE=1000000000000000000
PAYMENT_TOKEN_ADDRESS=0xc70B8741B8B07A6d61E54fd4B20f22Fa648E5565

# Bond: The agent wallet must hold bond tokens (same as PAYMENT_TOKEN_ADDRESS
# on testnet) to initiate UMA assertions. Minimum bond is ~0.1 token.
# The SDK auto-approves and initiates assertions after each job submission.

# Server
PORT=8003
JOB_TIMEOUT=120
