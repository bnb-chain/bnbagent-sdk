# examples/agent-server — see project-root .env.example for the full surface.

# --- Wallet (required) ---
WALLET_PASSWORD=demo-password
# First run only — after keystore is written under ~/.bnbagent/wallets, drop it.
PRIVATE_KEY=0x...
# Select a specific keystore if you have several.
# WALLET_ADDRESS=0x...

# --- Network ---
NETWORK=bsc-testnet
# RPC_URL=https://data-seed-prebsc-2-s2.binance.org:8545

# --- APEX overrides (defaults from NETWORK) ---
# APEX_COMMERCE_ADDRESS=0x1e677fc06ff772e81051484c8c3845fbef13986d
# APEX_ROUTER_ADDRESS=0x0c729baa3cdac6cc3fdef6a816f6bcb85ae92ed7
# APEX_POLICY_ADDRESS=0x459c3b7a46aa9dde45fbfc3b3d37bd062dbe6fb8

# Minimum budget this provider will accept (raw token units, 18 dp default).
APEX_SERVICE_PRICE=1000000000000000000
# /job/execute callback timeout in seconds.
APEX_EXEC_TIMEOUT=120

# --- Storage (IPFS via Pinata) ---
STORAGE_PROVIDER=ipfs
STORAGE_API_KEY=your_pinata_jwt_here
STORAGE_GATEWAY_URL=https://gateway.pinata.cloud/ipfs/

# --- Example-only (agent-server metadata + port) ---
AGENT_NAME=blockchain-news
AGENT_DESCRIPTION=Blockchain news search agent
AGENT_HOST=http://localhost:8003
PORT=8003
