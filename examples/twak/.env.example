# examples/twak — environment template.
# Copy to .env (or .env.local) next to the scripts; e2e_smoke.py loads it via
# bnbagent.load_env() with precedence: real env > .env.local > .env.

# ── e2e_smoke.py ────────────────────────────────────────────────────────────
# The only supported network for the smoke (it spends funds).
NETWORK=bsc-testnet

# REQUIRED: EVM key for the provider (seller) role. twak cannot submit a
# deliverable_url (gaps REQ-1), so an EVM wallet must play the provider.
# Needs a little testnet BNB for the submit transactions.
PROVIDER_PRIVATE_KEY=0x...

# Optional: a whitelisted OptimisticPolicy voter key. Casts one vote_reject
# on the disputed job (with the default quorum of 3, one vote cannot flip
# the verdict — the smoke asserts the vote is counted, nothing more).
#VOTER_PRIVATE_KEY=0x...

# Optional: when set, step 1 registers an ERC-8004 agent with this URI
# (mints a new agent NFT every run — hence opt-in).
#AGENT_URI=https://example.com/agent.json

# Optional: RPC override (e.g. a NodeReal endpoint with a higher
# get_logs block-range limit than the public default).
#RPC_URL=https://...

# ── all scripts ─────────────────────────────────────────────────────────────
# Pin a specific twak binary (defaults to `twak` on PATH).
#TWAK_BIN=./node_modules/.bin/twak

# Wallet unlock password, if not stored in the OS keychain
# (`twak wallet keychain save`). Reaches twak by env inheritance — INV-1:
# never on a command line.
#TWAK_WALLET_PASSWORD=...

# twak API credentials in env form (CI/containers) — the file form
# (~/.twak/credentials.json, written by `twak init`) also works.
#TWAK_ACCESS_ID=...
#TWAK_HMAC_SECRET=...
